# Copy this file to `local.properties` and fill in what you have.
# EVERYTHING HERE IS OPTIONAL — the app is fully functional with none of it set
# (offline verses + built-in gradient backgrounds, no sign-in required).

# Android SDK location (Android Studio sets this automatically on first sync).
sdk.dir=C\:\\Users\\YOUR_USER\\AppData\\Local\\Android\\Sdk

# --- Optional photo backgrounds ---
# Get a free key at https://unsplash.com/developers (preferred)
UNSPLASH_ACCESS_KEY=
# ...or https://www.pexels.com/api/ (used if Unsplash key is blank)
PEXELS_API_KEY=

# --- Optional Google Sign-In ---
# Web client ID from a Google Cloud OAuth 2.0 "Web application" credential.
GOOGLE_WEB_CLIENT_ID=

# --- Optional store/legal links (sensible defaults are used if blank) ---
PRIVACY_POLICY_URL=
TERMS_URL=
